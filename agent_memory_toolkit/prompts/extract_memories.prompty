      "object": "$50,000 for the current quarter",
      "confidence": 0.95,
      "salience": 0.9,
      "temporal_context": "current quarter",
      "tags": ["topic:budget", "topic:marketing"],
      "action": "ADD",
      "supersedes_id": null
    }
  ],
  "procedural": [
