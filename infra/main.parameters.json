{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION=eastus2}"
    },
    "principalId": {
      "value": "${AZURE_PRINCIPAL_ID}"
    },
    "deployFunctionApp": {
      "value": "${DEPLOY_FUNCTION_APP=true}"
    },
    "useExistingCosmos": {
      "value": "${USE_EXISTING_COSMOS=false}"
    },
    "existingCosmosAccountName": {
      "value": "${EXISTING_COSMOS_ACCOUNT=}"
    },
    "existingCosmosResourceGroup": {
      "value": "${EXISTING_COSMOS_RESOURCE_GROUP=}"
    },
    "useExistingAiFoundry": {
      "value": "${USE_EXISTING_AI_FOUNDRY=false}"
    },
    "existingAiFoundryName": {
      "value": "${EXISTING_AI_FOUNDRY_NAME=}"
    },
    "existingAiFoundryResourceGroup": {
      "value": "${EXISTING_AI_FOUNDRY_RESOURCE_GROUP=}"
    },
    "embeddingModelName": {
      "value": "${AI_FOUNDRY_EMBEDDING_MODEL_NAME=text-embedding-3-large}"
    },
    "embeddingDeploymentName": {
      "value": "${AI_FOUNDRY_EMBEDDING_DEPLOYMENT_NAME=}"
    },
    "chatModelName": {
      "value": "${AI_FOUNDRY_CHAT_MODEL_NAME=gpt-4o-mini}"
    },
    "chatDeploymentName": {
      "value": "${AI_FOUNDRY_CHAT_DEPLOYMENT_NAME=}"
    },
    "cosmosDatabaseName": {
      "value": "${COSMOS_DB_DATABASE=ai_memory}"
    }
  }
}
